# Copy this file to `.env` and fill in values. `.env` is gitignored.
# Load with `direnv`, `dotenv`, or `set -a; source .env; set +a`.

# Absolute path to your GCP service account JSON key file.
# The key must have BigQuery permissions on the target project.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/service-account-key.json

# GCP project ID used for BigQuery billing and the default dataset location.
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery location for datasets created by dbt (e.g. US, EU, us-central1).
BQ_LOCATION=US

# Optional: absolute path to a private planning/notes directory that mirrors this repo.
# Used by the project's CLAUDE.md so AI assistants can locate strategy and findings that
# don't belong in the public repo. Leave blank if you don't have one.
PRIVATE_NOTES_DIR=
